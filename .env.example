# Web search (Tavily)
TAVILY_API_KEY=

# Hugging Face (optional, for HF-hosted models)
HF_API_KEY=
NEXT_PUBLIC_HF_API_KEY=

# Ollama – leave blank to use the default (host.docker.internal:11434 in Docker,
# localhost:11434 otherwise)
OLLAMA_BASE_URL=

# RAG backend – leave blank to use the default (host.docker.internal:8001 in
# Docker, localhost:8001 otherwise)
NEXT_PUBLIC_RAG_API_URL=
NEXT_PUBLIC_API_URL=

# Voice API (optional)
NEXT_PUBLIC_VOICE_API_URL=
